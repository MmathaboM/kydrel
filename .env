# Disable ESLint during build to prevent build failures from linting errors
DISABLE_ESLINT_PLUGIN=true

# Disable CI mode so warnings don't break the build
CI=false

# Optional: Set build folder (default is 'build')
# BUILD_PATH=build

# Optional: Skip preflight checks
SKIP_PREFLIGHT_CHECK=true

# Optional: Generate source maps for debugging
# GENERATE_SOURCEMAP=false

# Optional: Set public URL for assets
# PUBLIC_URL=https://yourdomain.com